{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Sunda",
    "scopeName": "source.sunda",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#keywords-control"
        },
        {
            "include": "#keywords-declaration"
        },
        {
            "include": "#keywords-io"
        },
        {
            "include": "#keywords-function"
        },
        {
            "include": "#keywords-boolean"
        },
        {
            "include": "#keywords-block"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#punctuation"
        },
        {
            "include": "#function-call"
        },
        {
            "include": "#variables"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.sunda",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.sunda",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.sunda",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.sunda",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.integer.sunda",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "keywords-control": {
            "patterns": [
                {
                    "name": "keyword.control.conditional.sunda",
                    "match": "\\b(upami|lamun|lainna|lain lamun)\\b"
                },
                {
                    "name": "keyword.control.loop.sunda",
                    "match": "\\b(pikeun|bari|ngajalankeun|ti)\\b"
                }
            ]
        },
        "keywords-declaration": {
            "patterns": [
                {
                    "name": "keyword.other.declaration.sunda",
                    "match": "\\b(nyieun|ngadeklarasikeun)\\b"
                }
            ]
        },
        "keywords-io": {
            "patterns": [
                {
                    "name": "support.function.io.sunda",
                    "match": "\\b(tampilkeun|tanya|mangga_eusian)\\b"
                }
            ]
        },
        "keywords-function": {
            "patterns": [
                {
                    "name": "keyword.other.function.sunda",
                    "match": "\\b(fungsi|balikkeun)\\b"
                }
            ]
        },
        "keywords-boolean": {
            "patterns": [
                {
                    "name": "constant.language.boolean.sunda",
                    "match": "\\b(leres|lepat|true|false)\\b"
                }
            ]
        },
        "keywords-block": {
            "patterns": [
                {
                    "name": "keyword.control.block.sunda",
                    "match": "\\b(anggeus)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.sunda",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.arithmetic.sunda",
                    "match": "[+\\-*/%]"
                },
                {
                    "name": "keyword.operator.assignment.sunda",
                    "match": "="
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.terminator.sunda",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.sunda",
                    "match": ":"
                },
                {
                    "name": "punctuation.separator.comma.sunda",
                    "match": ","
                },
                {
                    "name": "punctuation.bracket.round.sunda",
                    "match": "[()]"
                },
                {
                    "name": "punctuation.bracket.square.sunda",
                    "match": "[\\[\\]]"
                }
            ]
        },
        "function-call": {
            "patterns": [
                {
                    "name": "entity.name.function.sunda",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.sunda",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}